VITE_APP_MODE=demo
VITE_STATIC_QR_DEMO=true
VITE_ENABLE_REMOTE_AI=false
VITE_ENABLE_REAL_OCR=false
VITE_ENABLE_BARCODE_LOOKUP=false

# Server-side only. Static QR demos do not need these.
# Never expose real keys as VITE_* variables.
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash

# Optional fallback provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Cloudflare Worker local development uses .dev.vars instead of this file.
# Copy only the secrets you use; never commit .dev.vars.
